{
  "version": 2,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "tree.html",    "use": "@vercel/static" },
    { "src": "tree.css",     "use": "@vercel/static" },
    { "src": "tree.js",      "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/index.py" },
    { "src": "/",         "dest": "/tree.html" },
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*\\.js)",  "dest": "/$1" }
  ]
}
